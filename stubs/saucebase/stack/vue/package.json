{
    "$schema": "https://json.schemastore.org/package.json",
    "private": true,
    "name": "saucebase",
    "description": "A complete saas boilerplace powered with Vue, Filament, InertiaJS, and more",
    "type": "module",
    "scripts": {
        "build": "vite build && vite build --ssr",
        "build:ssr": "vite build && vite build --ssr",
        "dev": "vite",
        "preview": "vite preview",
        "host": "vite --host",
        "format": "prettier --write resources/ modules/**/resources/",
        "format:check": "prettier --check resources/ modules/**/resources/",
        "test": "playwright test",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:headed": "playwright test --headed",
        "test:e2e:debug": "playwright test --debug",
        "test:e2e:report": "playwright show-report",
        "screenshots": "npm run build && tsx scripts/capture-screenshots.ts",
        "lint": "eslint ./resources ./modules/*/resources --fix --no-error-on-unmatched-pattern",
        "saucebase": "tsx saucebase.ts"
    },
    "devDependencies": {
        "@clack/prompts": "^1.4.0",
        "@eslint/js": "^10.0.1",
        "@faker-js/faker": "^10.4.0",
        "@go-task/cli": "^3.51.1",
        "@iconify/json": "^2.2.478",
        "@inertiajs/vue3": "^3.2.0",
        "@playwright/test": "^1.60.0",
        "@saucebase/laravel-playwright": "^1.0",
        "@tailwindcss/forms": "^0.5.11",
        "@tailwindcss/postcss": "^4.3.0",
        "@tailwindcss/typography": "^0.5.19",
        "@tailwindcss/vite": "^4.3.0",
        "@types/node": "^25.9.1",
        "@vitejs/plugin-vue": "^6.0.7",
        "@vue/eslint-config-typescript": "^14.7.0",
        "concurrently": "^9.2.1",
        "dotenv": "^17.4.2",
        "eslint": "^10.4.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-vue": "^10.9.1",
        "laravel-vite-plugin": "^3.1.0",
        "lint-staged": "^17.0.5",
        "picocolors": "^1.1.1",
        "postcss": "^8.5.15",
        "prettier": "^3.8.3",
        "prettier-plugin-organize-imports": "^4.3.0",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "shadcn-vue": "^2.7.3",
        "tailwindcss": "^4.3.0",
        "tsx": "^4.22.3",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.4",
        "unplugin-icons": "^23.0.1",
        "vite": "^8.0.14",
        "vue": "^3.5.34",
        "vue-tsc": "^3.3.1"
    },
    "dependencies": {
        "@fontsource-variable/jetbrains-mono": "^5.2.8",
        "@fontsource-variable/outfit": "^5.2.8",
        "@fontsource-variable/source-serif-4": "^5.2.9",
        "@inertiajs/vite": "^3.2.0",
        "@vue/server-renderer": "^3.5.34",
        "@vueuse/core": "^14.3.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "laravel-vue-i18n": "^2.8.0",
        "lucide-vue-next": "^1.0.0",
        "reka-ui": "^2.9.8",
        "tailwind-merge": "^3.6.0",
        "tw-animate-css": "^1.4.0",
        "vue-sonner": "^2.0.9"
    },
    "engines": {
        "node": ">=22.12.0",
        "npm": ">=10.5.1"
    },
    "lint-staged": {
        "**/*.{js,ts,vue}": [
            "eslint --fix",
            "prettier --write"
        ],
        "!(*.{js,ts,vue})": "prettier --write --ignore-unknown"
    }
}
