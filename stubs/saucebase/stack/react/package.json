{
    "$schema": "https://json.schemastore.org/package.json",
    "private": true,
    "name": "saucebase",
    "description": "A complete saas boilerplate powered with React, Filament, InertiaJS, and more",
    "type": "module",
    "scripts": {
        "build": "vite build && vite build --ssr",
        "build:ssr": "vite build && vite build --ssr",
        "dev": "vite",
        "preview": "vite preview",
        "host": "vite --host",
        "format": "prettier --write resources/ modules/**/resources/",
        "format:check": "prettier --check resources/ modules/**/resources/",
        "test": "playwright test",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:headed": "playwright test --headed",
        "test:e2e:debug": "playwright test --debug",
        "test:e2e:report": "playwright show-report",
        "screenshots": "npm run build && tsx scripts/capture-screenshots.ts",
        "lint": "eslint ./resources ./modules/*/resources --fix --no-error-on-unmatched-pattern"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@faker-js/faker": "^10.3.0",
        "@go-task/cli": "^3.48.0",
        "@iconify-json/circle-flags": "^1.2.10",
        "@iconify-json/fluent": "^1.2.50",
        "@iconify-json/heroicons": "^1.2.3",
        "@iconify-json/lucide": "^1.2.107",
        "@iconify-json/mdi": "^1.2.3",
        "@iconify-json/simple-icons": "^1.2.63",
        "@inertiajs/react": "^3.0.0",
        "@playwright/test": "^1.59.1",
        "@saucebase/laravel-playwright": "^1.0",
        "@svgr/core": "^8.1.0",
        "@svgr/plugin-jsx": "^8.1.0",
        "@tailwindcss/forms": "^0.5.11",
        "@tailwindcss/postcss": "^4.2.1",
        "@tailwindcss/typography": "^0.5.19",
        "@tailwindcss/vite": "^4.2.2",
        "@types/node": "^25.6.2",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@vitejs/plugin-react": "^6.0.0",
        "concurrently": "^10.0.3",
        "dotenv": "^17.3.1",
        "eslint": "^10.5.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-react-hooks": "^7.1.1",
        "laravel-vite-plugin": "^3.0.0",
        "lint-staged": "^17.0.7",
        "lucide-react": "^1.18.0",
        "postcss": "^8.5.6",
        "prettier": "^3.8.3",
        "prettier-plugin-organize-imports": "^4.3.0",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "shadcn": "^4.7.0",
        "tailwindcss": "^4.2.0",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.56.1",
        "unplugin-icons": "^23.0.1",
        "vite": "^8.0.0"
    },
    "dependencies": {
        "@fontsource-variable/jetbrains-mono": "^5.2.8",
        "@fontsource-variable/outfit": "^5.2.8",
        "@fontsource-variable/source-serif-4": "^5.2.9",
        "@inertiajs/vite": "^3.0.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "radix-ui": "^1.4.3",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "sonner": "^2.0.0",
        "tailwind-merge": "^3.5.0",
        "tw-animate-css": "^1.4.0"
    },
    "engines": {
        "node": ">=22.12.0",
        "npm": ">=10.5.1"
    },
    "lint-staged": {
        "**/*.{js,ts,tsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "!(*.{js,ts,tsx})": "prettier --write --ignore-unknown"
    },
    "version": "0.0.0"
}
