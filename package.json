{
    "$schema": "https://json.schemastore.org/package.json",
    "private": true,
    "name": "saucebase",
    "description": "A complete saas boilerplace powered with Vue, Filament, InertiaJS, and more",
    "type": "module",
    "scripts": {
        "build": "vite build && vite build --ssr",
        "build:ssr": "vite build && vite build --ssr",
        "dev": "vite",
        "preview": "vite preview",
        "host": "vite --host",
        "format": "prettier --write resources/ modules/**/resources/",
        "format:check": "prettier --check resources/ modules/**/resources/",
        "test": "playwright test",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:headed": "playwright test --headed",
        "test:e2e:debug": "playwright test --debug",
        "test:e2e:report": "playwright show-report",
        "screenshots": "npm run build && tsx scripts/capture-screenshots.ts",
        "lint": "eslint ./resources ./modules/*/resources --fix --no-error-on-unmatched-pattern",
        "saucebase": "tsx saucebase.ts"
    },
    "devDependencies": {
        "@clack/prompts": "^1.0.1",
        "@eslint/js": "^9.19.0",
        "@faker-js/faker": "^10.3.0",
        "@go-task/cli": "^3.48.0",
        "@iconify/json": "^2.2.443",
        "@inertiajs/vue3": "^3.0.0",
        "@playwright/test": "^1.58.2",
        "@saucebase/laravel-playwright": "^1.0",
        "@tailwindcss/forms": "^0.5.11",
        "@tailwindcss/postcss": "^4.2.1",
        "@tailwindcss/vite": "^4.2.2",
        "@vitejs/plugin-vue": "^6.0.0",
        "@vue/eslint-config-typescript": "^14.7.0",
        "concurrently": "^9.2.1",
        "dotenv": "^17.3.1",
        "eslint": "^9.39.3",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-vue": "^9.33.0",
        "laravel-vite-plugin": "^3.0.0",
        "lint-staged": "^16.2.7",
        "picocolors": "^1.1.1",
        "postcss": "^8.5.6",
        "prettier": "^3.8.1",
        "prettier-plugin-organize-imports": "^4.3.0",
        "prettier-plugin-tailwindcss": "^0.6.14",
        "shadcn-vue": "^2.4.3",
        "tailwindcss": "^4.2.0",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1",
        "unplugin-icons": "^22.5.0",
        "vite": "^8.0.0",
        "vue": "^3.4.0",
        "vue-tsc": "^2.2.12"
    },
    "dependencies": {
        "@inertiajs/vite": "^3.0.0",
        "@vue/server-renderer": "^3.5.22",
        "@vueuse/core": "^13.9.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "laravel-vue-i18n": "^2.8.0",
        "lucide-vue-next": "^0.525.0",
        "reka-ui": "^2.9.3",
        "tailwind-merge": "^3.5.0",
        "tw-animate-css": "^1.4.0",
        "vue-sonner": "^2.0.9"
    },
    "engines": {
        "node": ">=22.12.0",
        "npm": ">=10.5.1"
    },
    "lint-staged": {
        "**/*.{js,ts,vue}": [
            "eslint --fix",
            "prettier --write"
        ],
        "!(*.{js,ts,vue})": "prettier --write --ignore-unknown"
    }
}
