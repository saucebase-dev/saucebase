            "font-mono": "Source Code Pro, monospace",
            "font-body": "var(--font-sans)",
            "spacing": "0.275rem",
            "tracking-normal": "0.02em",
            "radius": "0rem",
            "shadow-blur": "0px",
            "shadow-spread": "0px",
            "shadow-offset-x": "2px",
            "shadow-offset-y": "2px",
            "radius-sm": "calc(0rem - 4px)",
            "radius-md": "calc(0rem - 2px)",
