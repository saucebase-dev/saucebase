{
    "$schema": "https://ui.shadcn.com/schema/registry-item.json",
    "name": "bento-box",
    "title": "Bento Box",
    "description": "Japanese lacquerware minimalism — black lacquer, white rice, and deep miso red",
    "type": "registry:style",
    "css": {
        "@layer base": {
            "body": {
                "letter-spacing": "var(--tracking-normal)"
            }
        }
    },
    "cssVars": {
        "theme": {
            "font-sans": "Noto Sans JP, sans-serif",
