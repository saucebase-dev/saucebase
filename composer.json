{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "saucebase/saucebase",
    "type": "project",
    "description": "A complete modular Laravel foundation for building SaaS applications.",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "cviebrock/eloquent-sluggable": "^13.0",
        "filament/actions": "^5.6.6",
        "filament/filament": "^5.6.6",
        "filament/forms": "^5.6.6",
        "filament/infolists": "^5.6.6",
        "filament/notifications": "^5.6.6",
        "filament/spatie-laravel-media-library-plugin": "^5.6.6",
        "filament/tables": "^5.6.6",
        "filament/widgets": "^5.6.6",
        "inertiajs/inertia-laravel": "^3.1",
        "internachi/modular": "^3.0.2",
        "laravel/ai": "^0.4.5",
        "laravel/framework": "^13.14",
        "laravel/sanctum": "^4.3.2",
        "laravel/tinker": "^3.0.2",
        "openplain/filament-shadcn-theme": "^1.1",
        "saucebase/breadcrumbs": "^1.1",
        "spatie/laravel-data": "^4.23",
        "spatie/laravel-navigation": "^1.3",
        "spatie/laravel-permission": "^6.25",
        "spatie/laravel-typescript-transformer": "^2.6",
        "tightenco/ziggy": "^2.6.2"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^3.7",
        "fakerphp/faker": "^1.24.1",
        "kkomelin/laravel-translatable-string-exporter": "^1.26",
        "larastan/larastan": "^3.10",
        "laravel/boost": "^2.4.9",
        "laravel/pail": "^1.2.7",
        "laravel/pint": "^1.29.1",
        "laravel/telescope": "^5.20",
        "mockery/mockery": "^1.6.12",
        "nunomaduro/collision": "^8.9.4",
        "phpunit/phpunit": "^12.5.29",
        "saucebase/laravel-playwright": "^1.1",
        "saucebase/module-installer": "^2.4.0",
        "symfony/filesystem": "^7.4.11"
    },
    "suggest": {
        "saucebase/announcements": "Site-wide announcement banners with scheduling, audience targeting, and cookie-based dismissal",
        "saucebase/auth": "Complete authentication system with login, registration, magic link, password reset, email verification, and OAuth",
        "saucebase/billing": "Subscription management and payment processing via Stripe with checkout, billing portal, and webhooks",
        "saucebase/demo": "Demo module with a variety of example pages and components to jumpstart your development",
        "saucebase/roadmap": "Public roadmap with feature requests, voting, moderation, and a Filament admin panel",
        "saucebase/settings": "Account settings pages for managing profile info, avatar, password, and connected social accounts",
        "saucebase/themes": "Visual theme editor for colors, fonts, radius, and shadows — baked into CSS with no runtime overhead",
        "saucebase/blog": "Full-featured blog with posts, categories, cover images, SEO metadata, and a Filament admin panel for content management"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Helpers/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install --ignore-scripts",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade",
            "@php artisan module:generate-types --all --no-interaction --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan vendor:publish --tag=livewire:assets --ansi --force",
            "@php artisan vendor:publish --tag=module-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "analyse": [
            "vendor/bin/phpstan analyse --memory-limit=2G"
        ],
        "ide-helper": [
            "@php artisan ide-helper:generate --ansi",
            "@php artisan ide-helper:meta --ansi"
        ],
        "lint": [
            "vendor/bin/pint"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "laravel/telescope"
            ]
        },
        "module-dir": "modules",
        "module-type": "saucebase-module"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true,
            "saucebase/module-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "authors": [
        {
            "name": "Saucebase",
            "email": "hello@saucebase.dev"
        },
        {
            "name": "Renan Roble",
            "email": "renanroble@gmail.com"
        }
    ],
    "keywords": [
        "laravel starter kit",
        "laravel boilerplate",
        "saas starter kit",
        "saas boilerplate"
    ],
    "repositories": [
        {
            "type": "path",
            "url": "modules/*",
            "canonical": false,
            "options": {
                "symlink": true
            }
        }
    ]
}
